<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- El widget lee los eventos que la app de Google ya sincroniza en el
         teléfono (CalendarProvider). No necesita internet ni inicio de sesión. -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_app"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.DualCalWidget">

        <!-- Pantalla de ayuda/permiso. Sin icono en el cajón de apps (no lleva
             LAUNCHER): se abre desde el propio widget si falta el permiso, para
             no duplicar icono con la PWA "DualCal". -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Actividad puente que abre DualCal como app (o navegador si falta) -->
        <activity
            android:name=".AbrirDualCalActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@style/Theme.Transparente" />

        <!-- Proveedor del widget de pantalla de inicio -->
        <receiver
            android:name=".AgendaWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.dualcal.widget.ACTION_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/agenda_widget_info" />
        </receiver>

        <!-- Servicio que alimenta la lista de eventos del widget -->
        <service
            android:name=".AgendaRemoteViewsService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />
    </application>
</manifest>
